    %vpi_call 2 50 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x55555620a280 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55555624ce30_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55555624cf80_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55555624d520_0, 0, 1;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0x55555624d390_0, 0, 8;
    %delay 100000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55555624cf80_0, 0, 1;
    %delay 100000, 0;
    %vpi_call 2 66 "$display", "--- Test 1: Sending 0xA5 ---" {0 0 0};
    %pushi/vec4 165, 0, 8;
    %store/vec4 v0x55555624d390_0, 0, 8;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55555624d520_0, 0, 1;
    %delay 20000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55555624d520_0, 0, 1;
T_5.0 ;
    %load/vec4 v0x55555624d170_0;
    %pushi/vec4 1, 0, 1;
    %cmp/e;
    %flag_get/vec4 4;
    %cmpi/ne 1, 0, 1;
    %jmp/0xz T_5.1, 6;
    %wait E_0x555556214310;
    %jmp T_5.0;
T_5.1 ;
    %load/vec4 v0x55555624d0d0_0;
    %cmpi/e 165, 0, 8;
    %jmp/0xz  T_5.2, 4;
    %vpi_call 2 77 "$display", "SUCCESS: Received 0x%h exactly as sent!", v0x55555624d0d0_0 {0 0 0};
    %jmp T_5.3;
T_5.2 ;
    %vpi_call 2 79 "$display", "ERROR: Sent 0xA5 but received 0x%h", v0x55555624d0d0_0 {0 0 0};
T_5.3 ;
    %delay 50000000, 0;
    %vpi_call 2 87 "$display", "--- Test 2: Sending 0x3C ---" {0 0 0};
    %pushi/vec4 60, 0, 8;
    %store/vec4 v0x55555624d390_0, 0, 8;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55555624d520_0, 0, 1;
    %delay 20000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55555624d520_0, 0, 1;
T_5.4 ;
    %load/vec4 v0x55555624d170_0;
    %pushi/vec4 1, 0, 1;
    %cmp/e;
    %flag_get/vec4 4;
    %cmpi/ne 1, 0, 1;
    %jmp/0xz T_5.5, 6;
    %wait E_0x555556214310;
    %jmp T_5.4;
T_5.5 ;
    %load/vec4 v0x55555624d0d0_0;
    %cmpi/e 60, 0, 8;
    %jmp/0xz  T_5.6, 4;
    %vpi_call 2 98 "$display", "SUCCESS: Received 0x%h exactly as sent!", v0x55555624d0d0_0 {0 0 0};
    %jmp T_5.7;
T_5.6 ;
    %vpi_call 2 100 "$display", "ERROR: Sent 0x3C but received 0x%h", v0x55555624d0d0_0 {0 0 0};
T_5.7 ;
    %delay 10000000, 0;
    %vpi_call 2 105 "$display", "--- Simulation Complete! You are ready for synthesis. ---" {0 0 0};
    %vpi_call 2 106 "$finish" {0 0 0};
    %end;
    .thread T_5;
